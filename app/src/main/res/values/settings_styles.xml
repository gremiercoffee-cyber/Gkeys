<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Gkeys.Settings" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/settings_card_bg</item>
        <item name="colorSecondary">@color/gkeys_accent</item>
        <item name="android:statusBarColor">@color/settings_screen_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/settings_screen_bg</item>
    </style>

    <style name="SettingsCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/settings_card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">6dp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>
</resources>
