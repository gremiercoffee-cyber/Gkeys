<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panel_setup"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:visibility="visible"
    android:scrollbars="vertical">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/SettingsCard"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gkeys"
                    android:textColor="@color/settings_card_text"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI-powered keyboard"
                    android:textColor="@color/settings_card_muted"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_enable_keyboard"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Enable Gkeys Keyboard"
                    android:textSize="16sp"
                    app:backgroundTint="@color/gkeys_accent"
                    app:cornerRadius="14dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/SettingsCard"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Appearance"
                    android:textColor="@color/settings_card_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Keyboard theme (settings screen stays light)"
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/radio_theme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_theme_dark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dark"
                        android:textColor="@color/settings_card_text"
                        android:buttonTint="@color/gkeys_accent"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                    <RadioButton
                        android:id="@+id/radio_theme_light"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Light"
                        android:textColor="@color/settings_card_text"
                        android:buttonTint="@color/gkeys_accent"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                </RadioGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_crash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#2A1A1A"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Last crash"
                    android:textColor="#FF8A80"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_crash_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#E5E7EB"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:maxLines="16"
                    android:scrollbars="vertical"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy_crash"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:text="Copy"
                        android:textSize="13sp"
                        app:backgroundTint="#3A2A2A"
                        android:layout_marginEnd="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_crash"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:text="Clear"
                        android:textSize="13sp"
                        app:backgroundTint="#3A2A2A"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/SettingsCard"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="API Keys"
                    android:textColor="@color/settings_card_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Keys are stored securely on this device using encrypted storage."
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mic_permission"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Allow microphone access"
                    android:textSize="14sp"
                    app:backgroundTint="@color/settings_card_input_bg"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_photo_permission"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Allow photos access"
                    android:textSize="14sp"
                    app:backgroundTint="@color/settings_card_input_bg"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lets recent screenshots appear in the clipboard so you can paste them."
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="OpenAI API Key (sk-...)"
                    app:hintTextColor="@color/settings_card_muted"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_openai_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/settings_card_text"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Anthropic API Key (sk-ant-...)"
                    app:hintTextColor="@color/settings_card_muted"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_anthropic_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/settings_card_text"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Deepgram API Key"
                    app:hintTextColor="@color/settings_card_muted"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_deepgram_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/settings_card_text"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
</LinearLayout>
</ScrollView>
