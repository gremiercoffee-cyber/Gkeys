<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/prompt_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1A2E"
    android:clickable="true"
    android:elevation="8dp"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/tv_prompt_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="4dp"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"
        android:text="Type with the keyboard below"
        android:textColor="#6B7280"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tv_prompt_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/clipboard_prompt_input_bg"
        android:minHeight="44dp"
        android:padding="12dp"
        android:textColor="#E8EAF0"
        android:textColorHint="#6B7280"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_prompt_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="Cancel"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_prompt_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="Save"
            android:textColor="#4A9EFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
