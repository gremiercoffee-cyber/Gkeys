<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panel_toolbar"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:visibility="gone"
    android:scrollbars="vertical">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/SettingsCard"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI Bar &amp; Voice"
                    android:textColor="@color/settings_card_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose which buttons appear and their order on the toolbar. Swipe the bar left or right for more icons. Mic is hidden while Voice Bubble mode is active."
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI bar voice input"
                    android:textColor="@color/settings_card_text"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mic only keeps dictation available — turn off the mic icon to use the floating bubble instead. Live transcribe is hidden in mic-only mode."
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radio_ai_bar_voice_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radio_voice_input_both"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Both mic and live transcribe"
                        android:textColor="@color/settings_card_muted"
                        android:buttonTint="#4A9EFF"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radio_voice_input_mic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mic only — tap to dictate"
                        android:textColor="@color/settings_card_muted"
                        android:buttonTint="#4A9EFF" />

                    <RadioButton
                        android:id="@+id/radio_voice_input_live"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Live transcribe only"
                        android:textColor="@color/settings_card_muted"
                        android:buttonTint="#4A9EFF" />

                </RadioGroup>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Toolbar icons"
                    android:textColor="@color/settings_card_text"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Long-press an icon and drag to reorder. Toggle items on or off."
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <com.gremier.gkeys.settings.FullyExpandedRecyclerView
                    android:id="@+id/rv_ai_bar_order"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Voice Bubble"
                            android:textColor="@color/settings_card_text"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Floating mic bubble button on the toolbar"
                            android:textColor="@color/settings_card_muted"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_voice_bubble_enabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Voice Bubble Mode"
                    android:textColor="@color/settings_card_text"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hide the keyboard and dictate through a floating bubble. Swipe up on the bubble to reopen the keyboard."
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/overlay_sideload_hint"
                    android:textColor="@color/settings_card_muted"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_overlay_permission"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Allow display over other apps"
                    android:textSize="14sp"
                    app:backgroundTint="@color/settings_card_input_bg"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/voice_bubble_default_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Default to Voice Bubble Mode"
                            android:textColor="@color/settings_card_text"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start text sessions with the keyboard hidden"
                            android:textColor="@color/settings_card_muted"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_default_voice_bubble"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_app_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Version"
            android:textColor="@color/settings_screen_muted"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
