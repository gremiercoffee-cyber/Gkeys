<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layoutDirection="ltr">

    <LinearLayout
        android:id="@+id/keyboard_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F0F1A"
        android:layoutDirection="ltr"
        android:paddingBottom="6dp">

        <!-- Single toolbar row: one-hand | clipboard pill | mic | keyboard -->
        <LinearLayout
            android:id="@+id/ai_strip"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="#1A1A2E"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical"
            android:layoutDirection="ltr">

            <TextView
                android:id="@+id/btn_one_hand"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="◧"
                android:textColor="#6B7280"
                android:textSize="15sp"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="One-handed mode" />

            <FrameLayout
                android:id="@+id/clipboard_area"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/clipboard_pill_bg"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="10dp">

                    <TextView
                        android:id="@+id/tv_clipboard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tap for clipboard"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_clipboard_toolbar"
                        android:contentDescription="Clipboard"
                        android:importantForAccessibility="no" />

                </LinearLayout>

            </FrameLayout>

            <FrameLayout
                android:id="@+id/btn_mic_container"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/ai_mic_bg"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/btn_mic"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mic_white"
                    android:contentDescription="Voice dictation"
                    android:clickable="false"
                    android:focusable="false"
                    android:importantForAccessibility="no" />

            </FrameLayout>

            <ImageButton
                android:id="@+id/btn_polish"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_polish"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="Polish text"
                android:scaleType="centerInside"
                android:padding="7dp" />

            <ImageButton
                android:id="@+id/btn_keyboard"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_keyboard_grid"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="Show keyboard"
                android:scaleType="centerInside"
                android:padding="8dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A3E" />

        <LinearLayout
            android:id="@+id/keyboard_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layoutDirection="ltr">

            <com.gremier.gkeys.ime.KeyboardTouchLayout
                android:id="@+id/keyboard_rows"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:orientation="vertical"
                android:layoutDirection="ltr"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

    <include layout="@layout/voice_overlay" />

    <FrameLayout
        android:id="@+id/polish_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#990F0F1A"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:indeterminate="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/polish_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Polishing…"
                android:textColor="#E5E7EB"
                android:textSize="14sp" />

        </LinearLayout>

    </FrameLayout>

    <FrameLayout
        android:id="@+id/clipboard_overlay_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>
