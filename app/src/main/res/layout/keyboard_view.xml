<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layoutDirection="ltr">

    <LinearLayout
        android:id="@+id/keyboard_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F0F1A"
        android:layoutDirection="ltr"
        android:paddingBottom="6dp">

        <!-- AI strip: centered AI mic + keyboard toggle -->
        <LinearLayout
            android:id="@+id/ai_strip"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:background="#1A1A2E"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical"
            android:layoutDirection="ltr">

            <View
                android:layout_width="44dp"
                android:layout_height="44dp" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">

                <FrameLayout
                    android:id="@+id/btn_mic_container"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/ai_mic_bg">

                    <ImageView
                        android:id="@+id/btn_mic"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_ai_mic"
                        android:contentDescription="Voice dictation"
                        android:clickable="true"
                        android:focusable="true" />

                </FrameLayout>

            </FrameLayout>

            <ImageButton
                android:id="@+id/btn_keyboard"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_keyboard_grid"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="Show keyboard"
                android:scaleType="centerInside"
                android:padding="10dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A3E" />

        <!-- Keyboard panel -->
        <LinearLayout
            android:id="@+id/keyboard_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layoutDirection="ltr">

            <LinearLayout
                android:id="@+id/keyboard_toolbar"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layoutDirection="ltr">

                <FrameLayout
                    android:id="@+id/clipboard_area"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_clipboard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:text="📋 Tap for clipboard"
                        android:textColor="#6B7280"
                        android:textSize="11sp"
                        android:singleLine="true"
                        android:ellipsize="end" />

                </FrameLayout>

                <TextView
                    android:id="@+id/btn_one_hand"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="◧"
                    android:textColor="#6B7280"
                    android:textSize="16sp"
                    android:background="@drawable/btn_circle_bg"
                    android:contentDescription="One-handed mode" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/keyboard_rows"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:orientation="vertical"
                android:layoutDirection="ltr"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

    <include layout="@layout/voice_overlay" />

    <FrameLayout
        android:id="@+id/clipboard_overlay_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>
