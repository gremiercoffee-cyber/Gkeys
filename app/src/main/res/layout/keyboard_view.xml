<?xml version="1.0" encoding="utf-8"?>

<FrameLayout

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"

    android:layout_height="wrap_content"

    android:background="@color/gkeys_bg"

    android:layoutDirection="ltr">



    <LinearLayout

        android:id="@+id/keyboard_content"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:background="@color/gkeys_bg"

        android:layoutDirection="ltr"

        android:paddingBottom="6dp"
        android:clipToPadding="false"
        android:clipChildren="false">



        <!-- Toolbar slot: AI bar OR word suggestions (Gboard-style swap) -->

        <FrameLayout

            android:id="@+id/toolbar_slot"

            android:layout_width="match_parent"

            android:layout_height="52dp"

            android:layoutDirection="ltr"

            android:paddingStart="2dp"

            android:paddingEnd="2dp"

            android:paddingTop="2dp"

            android:paddingBottom="2dp">



        <!-- Secondary AI bar (page 2 — settings, undo, bubble, …) -->

        <FrameLayout
            android:id="@+id/ai_bar_shell_secondary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <View
                android:id="@+id/ai_bar_bg_secondary"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/ai_bar_shell_bg" />

            <View
                android:id="@+id/ai_bar_shimmer_secondary"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/ai_bar_shimmer_sweep"
                android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ai_strip_secondary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="@android:color/transparent"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:gravity="center_vertical"
            android:layoutDirection="ltr">

            <ImageButton
                android:id="@+id/btn_ai_bar_back"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_back_arrow"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="Back to main toolbar"
                android:scaleType="centerInside"
                android:padding="5dp" />

            <TextView
                android:id="@+id/btn_polish_level"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="5dp"
                android:gravity="center"
                android:text="N"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/polish_toggle_bg"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Natural dictation — tap to change polish mode" />

            <ImageButton
                android:id="@+id/btn_raw_polish"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_polish"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="Polish text now"
                android:scaleType="centerInside"
                android:padding="5dp"
                android:visibility="gone"
                app:tint="@color/gkeys_accent" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_settings"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="Gkeys settings"
                android:scaleType="centerInside"
                android:padding="5dp" />

            <ImageButton
                android:id="@+id/btn_clipboard_undo"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_undo"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="Undo"
                android:scaleType="centerInside"
                android:padding="5dp" />

            <ImageButton
                android:id="@+id/btn_select_all"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_select_all"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="Select all"
                android:scaleType="centerInside"
                android:padding="5dp" />

            <ImageButton
                android:id="@+id/btn_voice_bubble"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_gkeys_mark_zoomed"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="Voice Bubble Mode — hide keyboard, dictate with floating bubble"
                android:scaleType="centerCrop"
                android:padding="2dp" />

            <View
                android:tag="ai_bar_spacer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

        </FrameLayout>



        <!-- Primary AI bar (page 1 — dictation, clipboard, mic, …) -->

        <FrameLayout
            android:id="@+id/ai_bar_shell_primary"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/ai_bar_bg_primary"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/ai_bar_shell_bg" />

            <View
                android:id="@+id/ai_bar_shimmer_primary"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/ai_bar_shimmer_sweep"
                android:visibility="gone" />

        <LinearLayout

            android:id="@+id/ai_strip"

            android:layout_width="match_parent"

            android:layout_height="match_parent"

            android:orientation="horizontal"

            android:background="@android:color/transparent"

            android:paddingStart="3dp"

            android:paddingEnd="3dp"

            android:gravity="center_vertical"

            android:layoutDirection="ltr">



            <ImageButton
                android:id="@+id/btn_ai_bar_page"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_chevron_forward"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="More toolbar options"
                android:scaleType="centerInside"
                android:padding="4dp" />



            <FrameLayout
                android:id="@+id/btn_wand"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Ghostwriter — tap for AI writing"
                android:foreground="?android:attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/wand_ai_sparkles"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/mic_sparkle_pair_gold"
                    android:alpha="0.95"
                    android:importantForAccessibility="no" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_ghostwriter_hand"
                    android:scaleType="centerInside"
                    android:importantForAccessibility="no" />

            </FrameLayout>

            <ImageButton
                android:id="@+id/btn_delete_forward"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_delete_forward"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="Delete forward"
                android:scaleType="centerInside"
                android:padding="5dp" />



            <ImageButton
                android:id="@+id/btn_clipboard_clear_all"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_clear_all"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="Clear all text"
                android:scaleType="centerInside"
                android:padding="5dp" />

            <FrameLayout
                android:id="@+id/clipboard_area"
                android:layout_width="84dp"
                android:layout_height="26dp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/clipboard_pill_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="4dp">

                    <LinearLayout
                        android:id="@+id/clipboard_preview_strip"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:longClickable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/iv_clipboard_preview"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone"
                            android:scaleType="centerCrop"
                            android:contentDescription="Recent clip preview" />

                        <TextView
                            android:id="@+id/tv_clipboard"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=""
                            android:textColor="@color/gkeys_text_primary"
                            android:textSize="10sp"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_clipboard_hint"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Clip"
                            android:textColor="@color/gkeys_text_secondary"
                            android:textSize="10sp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="2dp"
                        android:src="@drawable/ic_clipboard_toolbar"
                        android:contentDescription="Clipboard"
                        android:importantForAccessibility="no" />

                </LinearLayout>

            </FrameLayout>

            <ImageButton
                android:id="@+id/btn_live_transcribe"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_live_speech"
                android:background="@drawable/ai_bar_icon_btn_bg"
                android:contentDescription="Live transcribe — tap to start and stop"
                android:scaleType="centerInside"
                android:padding="5dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <LinearLayout
                android:id="@+id/mic_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clipChildren="false">

                <ImageButton
                    android:id="@+id/btn_mic_cancel"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/ic_cancel_recording"
                    android:background="@drawable/ai_bar_icon_btn_bg"
                    android:contentDescription="Cancel dictation"
                    android:scaleType="centerInside"
                    android:padding="5dp"
                    android:visibility="gone" />

            <FrameLayout

                android:id="@+id/btn_mic_container"

                android:layout_width="38dp"

                android:layout_height="38dp"

                android:background="@drawable/ai_mic_bg"

                android:clickable="true"

                android:focusable="true"

                android:clipChildren="false">



                <View

                    android:id="@+id/mic_ai_glow"

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:background="@drawable/mic_ai_glow_ring"

                    android:visibility="gone"

                    android:importantForAccessibility="no" />



                <View

                    android:id="@+id/mic_ai_shimmer"

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:background="@drawable/mic_shimmer_sweep"

                    android:visibility="gone"

                    android:importantForAccessibility="no" />



                <ImageView

                    android:id="@+id/mic_ai_sparkles"

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:src="@drawable/mic_sparkle_pair_gold"

                    android:visibility="visible"

                    android:alpha="0.95"

                    android:importantForAccessibility="no" />



                <ImageView

                    android:id="@+id/btn_mic"

                    android:layout_width="22dp"

                    android:layout_height="22dp"

                    android:layout_gravity="center"

                    android:src="@drawable/ic_mic_white"

                    android:contentDescription="Voice dictation"

                    android:clickable="false"

                    android:focusable="false"

                    android:importantForAccessibility="no" />



            </FrameLayout>

            </LinearLayout>



            <ImageButton

                android:id="@+id/btn_keyboard"

                android:layout_width="30dp"

                android:layout_height="30dp"

                android:layout_marginStart="5dp"

                android:src="@drawable/ic_dialpad"

                android:background="@drawable/ai_bar_icon_btn_bg"

                android:contentDescription="Number pad"

                android:scaleType="centerInside"

                android:padding="5dp" />



        </LinearLayout>

        </FrameLayout>



        <LinearLayout

            android:id="@+id/suggestion_strip"

            android:layout_width="match_parent"

            android:layout_height="match_parent"

            android:orientation="horizontal"

            android:background="@color/gkeys_suggestion_bar"

            android:gravity="center_vertical"

            android:visibility="gone"

            android:layoutDirection="ltr">



            <TextView

                android:id="@+id/suggestion_left"

                android:layout_width="0dp"

                android:layout_height="match_parent"

                android:layout_weight="1"

                android:gravity="center"

                android:textSize="15sp"

                android:textColor="@color/gkeys_text_secondary"

                android:maxLines="1"

                android:ellipsize="end"

                android:background="@drawable/suggestion_chip_ripple"

                android:clickable="true"

                android:focusable="true"

                android:paddingStart="6dp"

                android:paddingEnd="6dp" />



            <View

                android:id="@+id/suggestion_divider_left"

                android:layout_width="1dp"

                android:layout_height="22dp"

                android:background="@color/gkeys_divider"

                android:visibility="gone" />



            <TextView

                android:id="@+id/suggestion_center"

                android:layout_width="0dp"

                android:layout_height="match_parent"

                android:layout_weight="1.15"

                android:gravity="center"

                android:textSize="16sp"

                android:textStyle="bold"

                android:textColor="@color/gkeys_text_primary"

                android:maxLines="1"

                android:ellipsize="end"

                android:background="@drawable/suggestion_chip_ripple"

                android:clickable="true"

                android:focusable="true"

                android:paddingStart="6dp"

                android:paddingEnd="6dp" />



            <View

                android:id="@+id/suggestion_divider_right"

                android:layout_width="1dp"

                android:layout_height="22dp"

                android:background="@color/gkeys_divider"

                android:visibility="gone" />



            <ImageButton

                android:id="@+id/suggestion_dismiss"

                android:layout_width="46dp"

                android:layout_height="match_parent"

                android:src="@drawable/ic_backspace_close"

                android:background="@drawable/suggestion_chip_ripple"

                android:contentDescription="Back to AI bar"

                android:scaleType="centerInside"

                android:padding="10dp"

                android:tint="@color/gkeys_text_secondary" />



        </LinearLayout>



        </FrameLayout>



        <View

            android:layout_width="match_parent"

            android:layout_height="1dp"

            android:background="@color/gkeys_divider" />



        <TextView

            android:id="@+id/tv_status"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:visibility="gone"

            android:paddingStart="10dp"

            android:paddingEnd="10dp"

            android:paddingTop="5dp"

            android:paddingBottom="5dp"

            android:textSize="12sp"

            android:maxLines="3"

            android:ellipsize="end"

            android:gravity="center"

            android:textColor="@color/gkeys_accent" />



        <FrameLayout

            android:id="@+id/keyboard_panel"

            android:layout_width="match_parent"

            android:layout_height="220dp"

            android:layoutDirection="ltr"

            android:background="@color/gkeys_bg"

            android:clipToPadding="false"

            android:clipChildren="false">



            <FrameLayout

                android:id="@+id/keyboard_keys_host"

                android:layout_width="match_parent"

                android:layout_height="match_parent"

                android:background="@color/gkeys_bg">



                <com.gremier.gkeys.ime.KeyboardTouchLayout

                    android:id="@+id/keyboard_rows"

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:layout_gravity="bottom|center_horizontal"

                    android:orientation="vertical"

                    android:layoutDirection="ltr"

                    android:paddingStart="2dp"

                    android:paddingEnd="2dp"

                    android:paddingTop="2dp"

                    android:paddingBottom="2dp" />



            </FrameLayout>



            <include layout="@layout/voice_overlay" />

            <include layout="@layout/ghostwriter_overlay" />



            <FrameLayout

                android:id="@+id/clipboard_overlay_container"

                android:layout_width="match_parent"

                android:layout_height="match_parent"

                android:visibility="gone"

                android:clickable="true"

                android:focusable="true" />



        </FrameLayout>



    </LinearLayout>



</FrameLayout>

