<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panel_ai"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:visibility="gone"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI &amp; Dictation"
                    android:textColor="@color/settings_card_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dictation Polish"
                    android:textColor="@color/settings_card_text"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Formal: professional &amp; clear · Natural: remove ums, keep casual tone · Raw: transcript only — use the Polish button on the bar to polish manually"
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radio_polish_level"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radio_polish_formal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Formal"
                        android:textColor="@color/settings_card_muted"
                        android:buttonTint="@color/gkeys_accent" />

                    <RadioButton
                        android:id="@+id/radio_polish_natural"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Natural"
                        android:textColor="@color/settings_card_muted"
                        android:buttonTint="@color/gkeys_accent"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radio_polish_raw"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Raw"
                        android:textColor="@color/settings_card_muted"
                        android:buttonTint="@color/gkeys_accent" />

                </RadioGroup>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your Speech Profile"
                    android:textColor="@color/settings_card_text"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Describe how you speak — accent, pace, language mix, common phrases. Gkeys sends this with every AI request so transcription and polish match you."
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. I mix Hebrew and English, speak fast with lots of ums…"
                    app:hintTextColor="@color/settings_card_muted"
                    app:boxStrokeColor="@color/settings_card_muted"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxBackgroundColor="@color/settings_card_input_bg"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_speech_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="4"
                        android:maxLines="12"
                        android:maxHeight="180dp"
                        android:gravity="top|start"
                        android:scrollbars="vertical"
                        android:scrollbarStyle="insideInset"
                        android:overScrollMode="always"
                        android:nestedScrollingEnabled="true"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:lineSpacingMultiplier="1.15"
                        android:textColor="@color/settings_card_text"
                        android:textColorHint="@color/settings_card_muted"
                        android:inputType="textMultiLine|textCapSentences" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI Instructions"
                    android:textColor="@color/settings_card_text"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Custom rules sent with every AI request — dictation, polish, ghostwriter, and translate. Tell Gkeys what to always do or avoid."
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Don't add periods to short one-line messages in Raw mode…"
                    app:hintTextColor="@color/settings_card_muted"
                    app:boxStrokeColor="@color/settings_card_muted"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxBackgroundColor="@color/settings_card_input_bg"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_ai_instructions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="4"
                        android:maxLines="12"
                        android:maxHeight="180dp"
                        android:gravity="top|start"
                        android:scrollbars="vertical"
                        android:scrollbarStyle="insideInset"
                        android:overScrollMode="always"
                        android:nestedScrollingEnabled="true"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:lineSpacingMultiplier="1.15"
                        android:textColor="@color/settings_card_text"
                        android:textColorHint="@color/settings_card_muted"
                        android:inputType="textMultiLine|textCapSentences" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hold mic to translate"
                    android:textColor="@color/settings_card_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Long-press the mic, speak, then release. Output language is set below."
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speak in"
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinner_voice_from"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/clipboard_pill_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Output in"
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinner_voice_to"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/clipboard_pill_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
