<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:minHeight="48dp"
    android:background="?android:attr/selectableItemBackground">

    <ImageView
        android:id="@+id/iv_drag_handle"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_drag_handle"
        android:contentDescription="Drag to reorder"
        android:scaleType="centerInside"
        android:padding="2dp" />

    <ImageView
        android:id="@+id/iv_order_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/ai_bar_icon_btn_bg"
        android:padding="6dp"
        android:scaleType="centerInside"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/tv_order_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:textColor="@color/settings_card_text"
        android:textSize="14sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_order_enabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</LinearLayout>
