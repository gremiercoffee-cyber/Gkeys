<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panel_ai_models"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:visibility="gone"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI Models"
                    android:textColor="@color/settings_card_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="On-device AI predictions"
                            android:textColor="@color/settings_card_text"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Offline reranking only; no cloud inference"
                            android:textColor="@color/settings_card_muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_on_device_ai_predictions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_ai_model_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Model not installed"
                    android:textColor="@color/settings_card_text"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_ai_model_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Model installed: No"
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_ai_model_download"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"
                    app:indicatorColor="@color/gkeys_accent"
                    app:trackColor="@color/settings_card_input_bg" />

                <TextView
                    android:id="@+id/tv_ai_model_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/settings_card_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_download_ai_model"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Download recommended model"
                    android:textSize="13sp"
                    app:backgroundTint="@color/gkeys_accent"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_ai_model_download"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Cancel download"
                    android:textSize="13sp"
                    android:visibility="gone"
                    app:backgroundTint="@color/settings_card_input_bg"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_remove_ai_model"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Remove model"
                    android:textSize="13sp"
                    app:backgroundTint="@color/settings_card_input_bg" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
