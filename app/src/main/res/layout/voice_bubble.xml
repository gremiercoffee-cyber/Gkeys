<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"

    android:id="@+id/voice_bubble_root"

    android:layout_width="40dp"

    android:layout_height="wrap_content"

    android:contentDescription="Gkeys voice bubble. Tap to dictate. Hold to translate. Tap the text field for keyboard."

    android:importantForAccessibility="yes"

    android:clipChildren="false">



    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:gravity="center_horizontal"

        android:clipChildren="false">



        <FrameLayout

            android:id="@+id/bubble_body"

            android:layout_width="40dp"

            android:layout_height="57dp"

            android:background="@drawable/voice_bubble_icon_bg"

            android:clipChildren="false"

            android:importantForAccessibility="no">



            <View

                android:id="@+id/bubble_ai_glow"

                android:layout_width="match_parent"

                android:layout_height="match_parent"

                android:background="@drawable/voice_bubble_glow_rect"

                android:visibility="gone"

                android:importantForAccessibility="no" />



            <View

                android:id="@+id/bubble_ai_shimmer"

                android:layout_width="match_parent"

                android:layout_height="match_parent"

                android:background="@drawable/mic_shimmer_sweep"

                android:visibility="gone"

                android:importantForAccessibility="no" />



            <ImageView

                android:id="@+id/bubble_icon"

                android:layout_width="30dp"

                android:layout_height="30dp"

                android:layout_gravity="center"

                android:src="@drawable/ic_gkeys_mark_zoomed"

                android:scaleType="centerCrop"

                android:importantForAccessibility="no" />



        </FrameLayout>



        <ImageButton

            android:id="@+id/bubble_cancel"

            android:layout_width="28dp"

            android:layout_height="28dp"

            android:layout_marginTop="6dp"

            android:src="@drawable/ic_cancel_recording"

            android:background="@drawable/btn_circle_bg"

            android:contentDescription="Cancel dictation"

            android:scaleType="centerInside"

            android:padding="5dp"

            android:visibility="gone" />



    </LinearLayout>



</FrameLayout>
