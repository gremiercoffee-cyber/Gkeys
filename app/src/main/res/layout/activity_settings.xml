<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/settings_screen_bg">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/settings_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/settings_screen_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:tabMode="scrollable"
        app:tabTextColor="@color/settings_screen_muted"
        app:tabSelectedTextColor="@color/settings_screen_text"
        app:tabIndicatorColor="@color/gkeys_accent"
        app:tabRippleColor="@color/gkeys_ripple" />

    <FrameLayout
        android:id="@+id/settings_panel_host"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include layout="@layout/settings_panel_setup" />
        <include layout="@layout/settings_panel_ai" />
        <include layout="@layout/settings_panel_keyboard" />
        <include layout="@layout/settings_panel_toolbar" />

    </FrameLayout>

</LinearLayout>
