<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="60dp"
                android:startColor="#88A78BFA"
                android:endColor="#004A9EFF" />
        </shape>
    </item>
    <item
        android:top="4dp"
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#2A1F4E"
                android:endColor="#151030" />
            <stroke
                android:width="2dp"
                android:color="#A78BFA" />
        </shape>
    </item>
</layer-list>
